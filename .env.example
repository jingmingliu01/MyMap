AMAP_WEB_SERVICE_KEY=your_amap_web_service_key
AMAP_JS_API_KEY=your_amap_js_api_key
AMAP_JS_API_SECURITY_JS_CODE=your_amap_js_api_security_js_code
AMAP_JS_API_VERSION=2.0

APP_HOST=127.0.0.1
APP_PORT=5173
SCREENSHOT_FALLBACK_PORT=4173

AMAP_POI_PAGE_SIZE=25
AMAP_POI_MAX_PAGES=3
AMAP_POI_MAX_REQUEST_ATTEMPTS=3
AMAP_POI_REQUEST_TIMEOUT_MS=15000
AMAP_POI_RETRY_BACKOFF_MS=350

# Default LLM provider: DeepSeek V4 Flash with thinking enabled.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_EFFORT=high

# Optional OpenAI fallback. Set LLM_PROVIDER=openai to use this.
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.5

LLM_MAX_SELECTED_BRANCHES=5
LLM_MAX_SELECTED_ATTRACTION_BRANCHES=1

AI_MAX_TOOL_STEPS=8
AI_CONTEXT_MESSAGES=8
AI_MESSAGE_CHAR_LIMIT=2000
AI_CLIENT_MESSAGE_HISTORY=10

SCREENSHOT_WIDTH=1920
SCREENSHOT_HEIGHT=1080
SCREENSHOT_OUTPUT=output/mymap.png
SCREENSHOT_READY_TIMEOUT_MS=30000
SCREENSHOT_SETTLE_MS=3000
