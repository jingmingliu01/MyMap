{
  "name": "mymap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node scripts/run.mjs",
    "setup": "node scripts/run.mjs",
    "fetch:places": "tsx src/fetch-places.ts",
    "merge:points": "tsx src/merge-points.ts",
    "generate": "npm run fetch:places && npm run merge:points",
    "dev": "node scripts/dev.mjs",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test && npm run build",
    "test": "tsx --test \"src/**/*.test.ts\" \"app/**/*.test.tsx\"",
    "screenshot": "tsx src/screenshot.ts",
    "clean:data": "node scripts/clean-data.mjs"
  },
  "devDependencies": {
    "@amap/amap-jsapi-types": "^0.0.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^16.4.7",
    "jsdom": "^29.1.1",
    "playwright": "^1.52.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "next": "^16.2.5",
    "openai": "^6.36.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.4.3"
  }
}
